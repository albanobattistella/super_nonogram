{
    "files.exclude": {
        "android/.gradle/": true,
        "android/.kotlin/": true,
        "linux/flutter/ephemeral/": true,
        "*.iml": true,
        "submodules/*/*": true,
        "**/.dart_tool/": true,
        "**/.idea/": true,
        "**/.flutter-plugins-dependencies": true,
    },
    "editor.defaultFormatter": "Dart-Code.dart-code",
    "editor.formatOnSave": true,
    "dart.analysisExcludedFolders": [
        "submodules"
    ]
}
